<Window x:Class="ItrqTool.Presentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ItrqTool.Presentation.ViewModels"
        xmlns:views="clr-namespace:ItrqTool.Presentation.Views"
        Title="ItrqTool" Height="600" Width="900">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:WorkflowListViewModel}">
            <views:WorkflowListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkflowRunViewModel}">
            <views:WorkflowRunView/>
        </DataTemplate>
    </Window.Resources>
    <ContentControl Content="{Binding CurrentViewModel}"/>
</Window>
