<UserControl x:Class="ItrqTool.Presentation.Views.WorkflowListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="Workflows" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
        <Button DockPanel.Dock="Bottom"
                Content="Open"
                HorizontalAlignment="Left"
                Margin="0,12,0,0"
                Command="{Binding SelectCurrentCommand}"/>
        <ListBox ItemsSource="{Binding Workflows}"
                 SelectedItem="{Binding SelectedWorkflow}"
                 DisplayMemberPath="Name"/>
    </DockPanel>
</UserControl>
