<UserControl x:Class="ItrqTool.Presentation.Views.WorkflowRunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ItrqTool.Presentation.Converters">
    <UserControl.Resources>
        <converters:LogLevelShortConverter x:Key="LogLevelShortConverter"/>
        <converters:LogLevelColorConverter x:Key="LogLevelColorConverter"/>
    </UserControl.Resources>

    <DockPanel Margin="16">

        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12" LastChildFill="False">
            <Button Content="← Back"
                    Command="{Binding BackCommand}"
                    Padding="12,4"
                    DockPanel.Dock="Left"/>
            <TextBlock Text="{Binding WorkflowName}"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left"/>
            <Button Content="Open working folder"
                    Command="{Binding OpenWorkingFolderCommand}"
                    Padding="12,4"
                    DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- Run button (bottom) -->
        <Button DockPanel.Dock="Bottom"
                Content="{Binding RunButtonLabel}"
                Command="{Binding RunTaskCommand}"
                IsEnabled="{Binding CanRun}"
                IsDefault="True"
                HorizontalAlignment="Right"
                Padding="20,8"
                Margin="0,12,0,0"/>

        <!-- Main content: three rows — tasks+result | splitter | log panel -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Row 0: tasks (left) + result panel (right) -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ListBox Grid.Column="0"
                         ItemsSource="{Binding Tasks}"
                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Status}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Duration}"
                                           Foreground="Gray"
                                           Margin="8,0,0,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ContentControl Grid.Column="1"
                                Content="{Binding SelectedResult}"
                                Margin="16,0,0,0">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{Binding TaskName}"
                                           FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{Binding Duration}"
                                           Foreground="Gray"
                                           Margin="0,4,0,12"/>
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Severity}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Timestamp}"
                                                           Foreground="Gray"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Text}"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>

            <!-- Row 1: resizable splitter -->
            <GridSplitter Grid.Row="1" Height="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="#E5E5E5" Margin="0,4"/>

            <!-- Row 2: live log panel -->
            <Border Grid.Row="2" BorderBrush="#CCCCCC" BorderThickness="1" Padding="4">
                <DockPanel>
                <Button DockPanel.Dock="Top"
                        Content="Copy log"
                        Command="{Binding CopyLogCommand}"
                        HorizontalAlignment="Left"
                        Padding="8,2"
                        Margin="0,0,0,4"/>
                <ListBox x:Name="LogList"
                         ItemsSource="{Binding LogSink.Entries}"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Cascadia Mono, Courier New"
                         FontSize="12" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="2,0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTip="{Binding Category}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="78"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Level, Converter={StaticResource LogLevelShortConverter}}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelColorConverter}}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Timestamp, StringFormat='HH:mm:ss'}"
                                           Foreground="Gray"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ShortCategory}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="Gray"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Message}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
